{
 "name|@required":"string",
 "description|@required":"string",
 "author|@required":"string",
 "version|@required":"string",
 "preview|@required,filepath_flag(png)":"string",
 "simpleblocks|@required,list_flag(allow_multiple)":[
  {
   "uuid|@required,@unique":"string",
   "name|@required":"string",
   "description|@required":"string",
   "icon|@required,filepath_flag(png)":"string",
   "dif|filepath_flag(png)":"string",
   "nor|filepath_flag(png)":"string",
   "met|filepath_flag(png)":"string",
   "mesh|@required,filepath_flag(obj)":"string",
   "script|filepath_flag(lua)":"string",
   "collider|enum(wheel,sizable_wheel)":"string",
   "normScale|range_flag(exp)":"float",
   "smoothness|range_flag(linear)":"float",
   "scale|range_flag(exp)":"float",
   "colliderOptions|need(collider.value==collider.enum.slot(2))":{
    "SizeX|range_flag(exp)":"float",
    "SizeY|range_flag(exp)":"float",
    "SizeZ|range_flag(exp)":"float",
    "OffsetX":"float",
    "OffsetY":"float",
    "OffsetZ":"float"
   },
   "meshOptions|need(collider.value==collider.enum.slot(2))":{
    "OffsetY":"float"
   },
   "connections|list_flag(allow_multiple)":[
    {
     "type|@required,enum(signalReceiver,signalSender,signalReceiverSender)":"string",
     "color|@required,hex_flag(tag,no-alpha)":"string",
     "connectionsLimit|@required,range_flag(unsigned)":"int",
     "relativePosition|@required":{
      "X":"float",
      "Y":"float",
      "Z":"float"
     }
    }
   ]
  }
 ]
}